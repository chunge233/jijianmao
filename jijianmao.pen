                {
                  "type": "text",
                  "id": "kQANS",
                  "name": "Paragraph",
                  "fill": "$text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "请各位员工在6月20日前完成排班确认，如有特殊情况需调整班次，请提前联系主管。",
