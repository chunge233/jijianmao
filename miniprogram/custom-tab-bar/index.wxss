.tabbar-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  height: 160rpx;
  height: calc(160rpx + constant(safe-area-inset-bottom));
  height: calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: transparent;
  pointer-events: none;
}

.tabbar-panel {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  box-sizing: border-box;
  height: 112rpx;
  height: calc(112rpx + constant(safe-area-inset-bottom));
  height: calc(112rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: flex-start;
  padding: 12rpx;
  padding: 12rpx 12rpx calc(12rpx + constant(safe-area-inset-bottom));
  padding: 12rpx 12rpx calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.10);
  pointer-events: auto;
}

.tabbar-item {
  position: relative;
  flex: 1;
  height: 76rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-radius: 44rpx;
  color: #6B7280;
  font-weight: 400;
}

.tabbar-item.is-active {
  color: #1A56DB;
  font-weight: 600;
}

.tabbar-icon,
.tabbar-center-placeholder {
  width: 44rpx;
  height: 44rpx;
  flex: 0 0 44rpx;
  display: block;
}

.tabbar-label {
  max-width: 100%;
  color: inherit;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 22rpx;
  line-height: 28rpx;
  white-space: nowrap;
}

.tabbar-center-button {
  position: absolute;
  top: -60rpx;
  left: 50%;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #1A56DB;
  box-shadow: 0 6rpx 20rpx rgba(26, 86, 219, 0.30);
  transform: translateX(-50%);
}

.tabbar-center-icon {
  width: 56rpx;
  height: 56rpx;
  flex-basis: 56rpx;
}
