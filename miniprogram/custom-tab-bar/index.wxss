.tabbar-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  height: 160rpx;
  height: calc(160rpx + constant(safe-area-inset-bottom));
  height: calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: transparent;
  pointer-events: none;
}

.report-choice-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 998;
  display: flex;
  align-items: flex-end;
  padding: 28rpx 28rpx calc(150rpx + constant(safe-area-inset-bottom));
  padding: 28rpx 28rpx calc(150rpx + env(safe-area-inset-bottom));
  background: rgba(17, 24, 39, 0.42);
  pointer-events: auto;
}

.report-choice-sheet {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding: 18rpx 24rpx 24rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 18rpx 54rpx rgba(17, 24, 39, 0.18);
}

.choice-handle {
  width: 72rpx;
  height: 8rpx;
  align-self: center;
  border-radius: 999rpx;
  background: #D1D5DB;
}

.choice-header {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 0 4rpx;
}

.choice-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.choice-desc {
  color: #6B7280;
  font-size: 22rpx;
  line-height: 32rpx;
}

.choice-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.choice-card {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #F9FAFB;
}

.choice-icon {
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  background: #DBEAFE;
}

.choice-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.choice-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.choice-card-title {
  color: #111827;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.choice-card-desc {
  color: #6B7280;
  font-size: 22rpx;
  line-height: 32rpx;
}

.choice-arrow {
  width: 26rpx;
  height: 26rpx;
  flex: 0 0 26rpx;
}

.tabbar-panel {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  box-sizing: border-box;
  height: 112rpx;
  height: calc(112rpx + constant(safe-area-inset-bottom));
  height: calc(112rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: flex-start;
  padding: 12rpx;
  padding: 12rpx 12rpx calc(12rpx + constant(safe-area-inset-bottom));
  padding: 12rpx 12rpx calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.10);
  pointer-events: auto;
}

.tabbar-item {
  position: relative;
  flex: 1;
  height: 76rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-radius: 44rpx;
  color: #6B7280;
  font-weight: 400;
}

.tabbar-item.is-active {
  color: #1A56DB;
  font-weight: 600;
}

.tabbar-icon,
.tabbar-center-placeholder {
  width: 44rpx;
  height: 44rpx;
  flex: 0 0 44rpx;
  display: block;
}

.tabbar-label {
  max-width: 100%;
  color: inherit;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 22rpx;
  line-height: 28rpx;
  white-space: nowrap;
}

.tabbar-center-button {
  position: absolute;
  top: -60rpx;
  left: 50%;
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #1A56DB;
  box-shadow: 0 6rpx 20rpx rgba(26, 86, 219, 0.30);
  transform: translateX(-50%);
}

.tabbar-center-icon {
  width: 56rpx;
  height: 56rpx;
  flex-basis: 56rpx;
}
