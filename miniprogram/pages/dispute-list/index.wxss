@import "../../styles/replica.wxss";

.dispute-page {
  min-height: 100vh;
  background: #FFFFFF;
}

.dispute-tabs {
  height: 84rpx;
  display: flex;
  align-items: center;
  border-bottom: 1px solid #F3F4F6;
  background: #FFFFFF;
}

.dispute-tab {
  position: relative;
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6B7280;
  font-size: 26rpx;
}

.dispute-tab.active {
  color: #1A56DB;
  font-weight: 700;
}

.indicator {
  position: absolute;
  bottom: 0;
  width: 70rpx;
  height: 5rpx;
  border-radius: 3rpx;
  background: #1A56DB;
}

.search-wrap {
  padding: 12rpx 28rpx;
  background: #FFFFFF;
}

.search-box {
  height: 64rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: #F9FAFB;
  color: #9CA3AF;
  font-size: 24rpx;
}

.search-box image {
  width: 28rpx;
  height: 28rpx;
}

.dispute-list {
  padding-bottom: calc(72rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(72rpx + env(safe-area-inset-bottom));
}

.dispute-card {
  height: 168rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 18rpx;
  padding: 22rpx 28rpx;
  background: #FFFFFF;
}

.card-top,
.card-bottom {
  display: flex;
  align-items: center;
}

.card-top {
  gap: 20rpx;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
  border-radius: 32rpx;
  background: #DBEAFE;
  color: #1A56DB;
  font-size: 26rpx;
  font-weight: 700;
}

.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.name {
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.reason {
  overflow: hidden;
  color: #6B7280;
  font-size: 23rpx;
  line-height: 32rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-bottom {
  justify-content: space-between;
  color: #9CA3AF;
  font-size: 21rpx;
}

.card-bottom image {
  width: 28rpx;
  height: 28rpx;
}

.divider {
  height: 1px;
  background: #F3F4F6;
}

.empty-state {
  padding: 80rpx 28rpx;
  color: #9CA3AF;
  font-size: 24rpx;
  text-align: center;
}
