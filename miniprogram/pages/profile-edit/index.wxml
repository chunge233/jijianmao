<nav-bar title="个人资料" show-back="{{true}}" back-text="" back-icon="/assets/icons/caret-left-black.svg" back-color="#111827"></nav-bar>

<view class="profile-edit-page">
  <view class="profile-edit-content">
    <view class="avatar-section">
      <view class="avatar {{!isLoggedIn ? 'avatar-guest' : ''}}">
        <image wx:if="{{!isLoggedIn}}" class="default-avatar-icon" src="{{defaultAvatarIcon}}" mode="aspectFit"></image>
        <text wx:else>{{avatarText}}</text>
      </view>
      <view wx:if="{{isLoggedIn}}" class="edit-avatar">
        <image src="/assets/icons/camera-blue.svg" mode="aspectFit"></image>
        <text>头像由姓名生成</text>
      </view>
    </view>

    <view class="field">
      <text class="field-label">姓名</text>
      <input
        class="native-input profile-input"
        value="{{nickname}}"
        placeholder="请输入姓名"
        placeholder-class="profile-placeholder"
        bindinput="onNicknameInput"
      />
    </view>

    <view class="field">
      <text class="field-label">手机号</text>
      <view class="native-input value readonly">{{maskedPhone}}</view>
    </view>

    <view class="field">
      <text class="field-label">所属工厂</text>
      <view class="native-input value readonly">{{factoryName}}</view>
    </view>

    <view class="primary-button save-button {{saving ? 'disabled' : ''}}" bindtap="saveProfile">
      {{saving ? '保存中...' : '保存'}}
    </view>
  </view>
</view>
