@import "../../styles/replica.wxss";

.settings-page {
  min-height: 100vh;
  background: #FFFFFF;
}

.settings-content {
  display: flex;
  flex-direction: column;
  padding-top: 24rpx;
  padding-bottom: calc(72rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(72rpx + env(safe-area-inset-bottom));
}

.settings-row {
  height: 96rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 0 32rpx;
  background: #FFFFFF;
}

.row-icon {
  width: 36rpx;
  height: 36rpx;
  flex: 0 0 36rpx;
}

.row-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.row-copy text:first-child {
  color: #111827;
  font-size: 25rpx;
  font-weight: 600;
}

.row-copy text:last-child {
  color: #6B7280;
  font-size: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cache-value {
  color: #6B7280;
  font-size: 22rpx;
}

.arrow {
  width: 26rpx;
  height: 26rpx;
  flex: 0 0 26rpx;
}

.section-gap {
  height: 24rpx;
  background: #F3F4F6;
}

.logout-row {
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
  background: #FFFFFF;
  color: #EF4444;
  font-size: 27rpx;
  font-weight: 600;
}
