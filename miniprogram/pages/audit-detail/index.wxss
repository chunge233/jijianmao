@import "../../styles/replica.wxss";

.audit-detail-page {
  min-height: 100vh;
  background: #FFFFFF;
}

.detail-content {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding: 36rpx 28rpx calc(72rpx + constant(safe-area-inset-bottom));
  padding: 36rpx 28rpx calc(72rpx + env(safe-area-inset-bottom));
}

.worker-card,
.info-card {
  border-radius: 17rpx;
  background: #F3F4F6;
}

.worker-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
}

.avatar {
  width: 84rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 84rpx;
  border-radius: 42rpx;
  background: #E8F0FE;
  color: #1A56DB;
  font-size: 35rpx;
  font-weight: 700;
}

.worker-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.worker-name {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.worker-role {
  color: #6B7280;
  font-size: 22rpx;
}

.info-card {
  overflow: hidden;
}

.info-row {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  color: #6B7280;
  font-size: 24rpx;
}

.info-row text:last-child {
  color: #111827;
  font-weight: 500;
}

.info-row .highlight {
  color: #1A56DB;
  font-weight: 700;
}

.divider {
  height: 1px;
  background: #E5E7EB;
}

.action-row {
  display: flex;
  gap: 14rpx;
}

.reject,
.approve {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.reject {
  border: 1px solid #EF4444;
  color: #EF4444;
}

.approve {
  background: #1A56DB;
  color: #FFFFFF;
}
