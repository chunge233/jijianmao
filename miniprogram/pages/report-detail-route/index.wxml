<nav-bar title="报工详情-工艺路线" show-back="{{true}}"></nav-bar>

<view class="route-detail-page">
  <view class="route-detail-content">
    <view wx:if="{{isEmpty}}" class="empty-card">
      <text class="empty-title">{{emptyTitle}}</text>
      <text class="empty-desc">{{emptyDesc}}</text>
    </view>

    <block wx:else>
    <view class="head-card">
      <view class="head-top">
        <text class="head-title">{{title}}</text>
        <text class="status-tag tag-{{statusTone}}">{{statusText}}</text>
      </view>
      <view class="head-meta">
        <text class="type-tag route-type">工艺路线</text>
        <text>{{createdAt}}</text>
      </view>
      <view class="summary-row">
        <view>
          <text class="summary-value">{{stepCount}}</text>
          <text>工序数</text>
        </view>
        <view>
          <text class="summary-value">{{totalQuantity}}</text>
          <text>总件数</text>
        </view>
        <view>
          <text class="summary-value amount">{{totalAmount}}</text>
          <text>合计金额</text>
        </view>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">工艺路线明细</text>
      <view class="route-grid table-head">
        <text>工序</text>
        <text>单价</text>
        <text>数量</text>
        <text>小计</text>
      </view>
      <block wx:for="{{steps}}" wx:key="name">
        <view class="route-grid table-row">
          <view class="name-cell">
            <text>{{item.name}}</text>
            <text wx:if="{{item.terminal}}" class="terminal-tag">末端</text>
          </view>
          <text>{{item.price}}</text>
          <text>{{item.count}}</text>
          <text class="amber-text strong">{{item.amount}}</text>
        </view>
      </block>
      <view class="route-total">
        <text>合计</text>
        <text>{{totalAmount}}</text>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">现场图片</text>
      <view class="photo-row">
        <block wx:for="{{photos}}" wx:key="*this">
          <view class="detail-photo">
            <image src="/assets/icons/image-square-gray.svg" mode="aspectFit"></image>
          </view>
        </block>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">表单备注</text>
      <text class="paragraph">{{remark}}</text>
    </view>

    <view class="section-card">
      <text class="section-title">审核信息</text>
      <block wx:for="{{audit}}" wx:key="label">
        <view class="info-row">
          <text>{{item.label}}</text>
          <text class="{{item.tone === 'amber' ? 'amber-text strong' : ''}} {{item.tone === 'green' ? 'green-text strong' : ''}} {{item.tone === 'red' ? 'red-text strong' : ''}}">{{item.value}}</text>
        </view>
      </block>
    </view>
    </block>
  </view>
</view>
