@import "../../styles/replica.wxss";

.route-detail-page {
  min-height: 100vh;
  background: #F3F4F6;
}

.route-detail-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 14rpx 14rpx calc(72rpx + constant(safe-area-inset-bottom));
  padding: 14rpx 14rpx calc(72rpx + env(safe-area-inset-bottom));
}

.head-card,
.section-card {
  border-radius: 14rpx;
  background: #FFFFFF;
}

.head-card,
.section-card {
  padding: 20rpx;
}

.head-top,
.head-meta,
.summary-row,
.photo-row,
.info-row,
.route-total {
  display: flex;
  align-items: center;
}

.head-top,
.info-row,
.route-total {
  justify-content: space-between;
}

.head-title {
  color: #111827;
  font-size: 29rpx;
  font-weight: 700;
}

.head-meta {
  gap: 12rpx;
  margin-top: 14rpx;
  color: #6B7280;
  font-size: 22rpx;
}

.type-tag {
  border-radius: 6rpx;
  padding: 2rpx 8rpx;
  background: #FEF3C7;
  color: #D97706;
  font-size: 18rpx;
  font-weight: 600;
}

.summary-row {
  justify-content: space-around;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1px solid #F3F4F6;
  color: #6B7280;
  font-size: 21rpx;
  text-align: center;
}

.summary-row view {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.summary-value {
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.summary-value.amount {
  color: #D97706;
}

.section-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-title {
  color: #111827;
  font-size: 24rpx;
  font-weight: 700;
}

.route-grid {
  display: grid;
  grid-template-columns: 1fr 110rpx 90rpx 120rpx;
  align-items: center;
  column-gap: 12rpx;
}

.table-head {
  color: #6B7280;
  font-size: 21rpx;
  font-weight: 500;
}

.table-row {
  min-height: 48rpx;
  color: #111827;
  font-size: 23rpx;
}

.name-cell {
  display: flex;
  align-items: center;
  gap: 7rpx;
  font-weight: 700;
}

.terminal-tag {
  border-radius: 6rpx;
  padding: 2rpx 8rpx;
  background: #FEF3C7;
  color: #D97706;
  font-size: 16rpx;
  font-weight: 600;
}

.strong {
  font-weight: 700;
}

.route-total {
  padding-top: 14rpx;
  border-top: 1px solid #F3F4F6;
  color: #D97706;
  font-size: 24rpx;
  font-weight: 700;
}

.photo-row {
  gap: 14rpx;
}

.detail-photo {
  width: 155rpx;
  height: 124rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  background: #F3F4F6;
}

.detail-photo image {
  width: 34rpx;
  height: 34rpx;
}

.paragraph {
  color: #6B7280;
  font-size: 23rpx;
  line-height: 36rpx;
}

.info-row {
  color: #6B7280;
  font-size: 23rpx;
  line-height: 34rpx;
}

.info-row text:last-child {
  color: #111827;
  font-weight: 600;
}
