@import "../../styles/replica.wxss";

.permission-page {
  min-height: 100vh;
  background: #FFFFFF;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 28rpx;
  background: #FFFFFF;
}

.mini-add {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 58rpx;
  border-radius: 12rpx;
  background: #1A56DB;
}

.mini-add image {
  width: 32rpx;
  height: 32rpx;
}

.search-box {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  background: #F9FAFB;
  color: #9CA3AF;
  font-size: 24rpx;
}

.search-box image {
  width: 28rpx;
  height: 28rpx;
}

.role-filters {
  height: 68rpx;
  display: flex;
  align-items: center;
  gap: 42rpx;
  padding: 0 36rpx;
  color: #6B7280;
  font-size: 24rpx;
}

.role-filters .active {
  color: #1A56DB;
  font-weight: 700;
}

.role-list {
  padding-bottom: calc(72rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(72rpx + env(safe-area-inset-bottom));
}

.role-row {
  height: 126rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 0 28rpx;
  background: #FFFFFF;
}

.indicator {
  width: 8rpx;
  height: 70rpx;
  flex: 0 0 8rpx;
  border-radius: 6rpx;
}

.role-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.role-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.role-name {
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
}

.role-count {
  color: #6B7280;
  font-size: 21rpx;
}

.role-summary {
  overflow: hidden;
  color: #6B7280;
  font-size: 21rpx;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  width: 30rpx;
  height: 30rpx;
}

.divider {
  height: 1px;
  margin-left: 28rpx;
  background: #F3F4F6;
}
