@import "../../styles/replica.wxss";

.factory-create-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

.factory-create-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx 20rpx 0;
}

.logo-section {
  display: flex;
  justify-content: center;
  padding: 4rpx 0 10rpx;
}

.factory-logo {
  width: 112rpx;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border: 2rpx solid #1A56DB;
  border-radius: 56rpx;
  color: #1A56DB;
  font-size: 17rpx;
}

.factory-logo image {
  width: 34rpx;
  height: 34rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.field-label {
  color: #111827;
  font-size: 24rpx;
  font-weight: 600;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.type-chip {
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #F3F4F6;
  color: #6B7280;
  font-size: 21rpx;
}

.area-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.area-select {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  color: #9CA3AF;
  font-size: 23rpx;
}

.area-select image {
  width: 24rpx;
  height: 24rpx;
}

.bottom-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 20rpx 20rpx calc(72rpx + constant(safe-area-inset-bottom));
  padding: 20rpx 20rpx calc(72rpx + env(safe-area-inset-bottom));
  color: #6B7280;
  font-size: 20rpx;
  text-align: center;
}
