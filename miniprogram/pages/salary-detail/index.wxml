<nav-bar title="工资详情" show-back="{{true}}"></nav-bar>

<view class="salary-detail-page">
  <view class="salary-detail-content">
    <view class="salary-head-card">
      <view class="salary-head-top">
        <text>2026年6月工资</text>
        <text class="status-tag tag-amber">待确认</text>
      </view>
      <text class="salary-big">¥2,580.00</text>
      <view class="salary-stat-row">
        <block wx:for="{{stats}}" wx:key="label">
          <view class="salary-stat">
            <text class="stat-value {{item.tone}}">{{item.value}}</text>
            <text>{{item.label}}</text>
          </view>
        </block>
      </view>
    </view>

    <view class="detail-card">
      <text class="card-title">工资明细</text>
      <block wx:for="{{details}}" wx:key="name">
        <view class="detail-row">
          <view class="row-left">
            <view class="dot" style="background: {{item.color}};"></view>
            <text class="detail-name">{{item.name}}</text>
            <text class="detail-meta">{{item.meta}}</text>
          </view>
          <text class="detail-amount">{{item.amount}}</text>
        </view>
      </block>
      <view class="divider"></view>
      <view class="total-row">
        <text>合计</text>
        <text>¥2,580.00</text>
      </view>
      <view class="detail-link" bindtap="openBreakdown">
        <text>查看工资明细</text>
        <image src="/assets/icons/caret-right-blue.svg" mode="aspectFit"></image>
      </view>
    </view>

    <view class="action-card">
      <text class="card-title">工资确认</text>
      <text class="action-hint">请核对工资明细，如有疑问可提出异议</text>
      <view class="action-row">
        <view class="confirm-button" bindtap="openBreakdown">确认无误</view>
        <view class="dispute-button" bindtap="openDispute">提出异议</view>
      </view>
    </view>
  </view>
</view>
