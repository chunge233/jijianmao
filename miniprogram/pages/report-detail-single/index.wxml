<nav-bar title="报工详情-单工序" show-back="{{true}}"></nav-bar>

<view class="detail-page">
  <view class="detail-content">
    <view wx:if="{{isEmpty}}" class="empty-card">
      <text class="empty-title">{{emptyTitle}}</text>
      <text class="empty-desc">{{emptyDesc}}</text>
    </view>

    <block wx:else>
    <view class="head-card">
      <view class="head-top">
        <text class="head-title">{{title}}</text>
        <text class="status-tag tag-{{statusTone}}">{{statusText}}</text>
      </view>
      <view class="head-meta">
        <text class="type-tag">单工序</text>
        <text>{{createdAt}}</text>
      </view>
    </view>

    <view class="table-card">
      <view class="single-grid table-head">
        <text>工序</text>
        <text>单价</text>
        <text>数量</text>
        <text>小计</text>
      </view>
      <view class="single-grid table-row">
        <text class="strong">{{detail.processName}}</text>
        <text>{{detail.price}}</text>
        <text>{{detail.quantity}}</text>
        <text class="amber-text strong">{{detail.amount}}</text>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">现场图片</text>
      <view class="photo-row">
        <block wx:for="{{photos}}" wx:key="*this">
          <view class="detail-photo">
            <image src="/assets/icons/image-square-gray.svg" mode="aspectFit"></image>
          </view>
        </block>
      </view>
    </view>

    <view class="section-card">
      <text class="section-title">表单备注</text>
      <text class="paragraph">{{remark}}</text>
    </view>

    <view class="section-card">
      <text class="section-title">审核信息</text>
      <block wx:for="{{audit}}" wx:key="label">
        <view class="info-row">
          <text>{{item.label}}</text>
          <text class="{{item.tone === 'green' ? 'green-text strong' : ''}} {{item.tone === 'red' ? 'red-text strong' : ''}} {{item.tone === 'amber' ? 'amber-text strong' : ''}}">{{item.value}}</text>
        </view>
      </block>
    </view>
    </block>
  </view>
</view>
