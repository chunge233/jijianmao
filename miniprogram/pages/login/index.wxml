<nav-bar title="登录" show-back="{{true}}"></nav-bar>

<view class="login-page">
  <view class="login-content">
    <view class="logo-area">
      <view class="logo-box">
        <image src="/assets/icons/clipboard-text-white.svg" mode="aspectFit"></image>
      </view>
      <text class="app-name">计件猫</text>
      <text class="slogan">工厂计件工资管理</text>
    </view>

    <view class="form-card">
      <input
        class="native-input login-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="login-placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
      <view class="code-row">
        <input
          class="native-input code-input login-input"
          type="number"
          maxlength="6"
          placeholder="请输入验证码"
          placeholder-class="login-placeholder"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <view class="code-button {{canSendCode ? '' : 'is-disabled'}}" bindtap="sendCode">{{codeButtonText}}</view>
      </view>
      <view class="primary-button {{loggingIn ? 'is-disabled' : ''}}" bindtap="goFactorySelect">{{loggingIn ? '登录中' : '登录'}}</view>
      <view class="agreement-row">
        <view class="agree-circle {{agreed ? 'is-checked' : ''}}" bindtap="toggleAgree"></view>
        <text>登录即同意</text>
        <text class="link">《用户协议》</text>
        <text>及</text>
        <text class="link">《隐私政策》</text>
      </view>
    </view>

    <text class="bottom-hint">首次登录将自动注册账号</text>
  </view>
</view>
