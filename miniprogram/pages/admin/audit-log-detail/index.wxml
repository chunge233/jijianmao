<nav-bar title="日志详情" show-back="{{true}}" back-text="" back-icon="/assets/icons/caret-left-black.svg" back-color="#111827"></nav-bar>

<view class="admin-page">
  <view class="admin-content">
    <view class="admin-card detail-head">
      <text>{{title}}</text>
      <text>{{subtitle}}</text>
      <text>{{source}}</text>
    </view>
    <view class="admin-section-title">变更前后</view>
    <view class="admin-card">
      <block wx:for="{{changes}}" wx:key="label">
        <view class="change-row">
          <text>{{item.label}}</text>
          <view class="change-values">
            <text>{{item.before}}</text>
            <text>→</text>
            <text>{{item.after}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
