<nav-bar title="数据备份" show-back="{{true}}" back-text="" back-icon="/assets/icons/caret-left-black.svg" back-color="#111827"></nav-bar>

<view class="admin-page backup-page">
  <view class="admin-content backup-content">
    <view class="status-card admin-card">
      <image src="/assets/icons/cloud-arrow-up-gray.svg" mode="aspectFit"></image>
      <view class="row-copy">
        <text class="row-title">备份正常</text>
        <text class="row-desc">上次自动备份：今天 23:00 · 保留30天</text>
      </view>
    </view>
    <view class="admin-card">
      <view class="admin-row">
        <view class="row-copy"><text class="row-title">备份频率</text><text class="row-desc">每天 23:00 自动备份</text></view>
      </view>
      <view class="admin-row">
        <view class="row-copy"><text class="row-title">云端存储</text><text class="row-desc">已使用 128MB / 2GB</text></view>
      </view>
    </view>
    <view class="admin-section-title">历史备份</view>
    <view class="admin-card">
      <block wx:for="{{histories}}" wx:key="date">
        <view class="admin-row">
          <view class="row-copy">
            <text class="row-title">{{item.date}}</text>
            <text class="row-desc">{{item.status}} · {{item.size}}</text>
          </view>
          <text class="blue-text">下载</text>
        </view>
      </block>
    </view>
  </view>
  <view class="fixed-bottom two-actions">
    <view class="outline-action" bindtap="openRestore">恢复数据</view>
    <view class="primary-action" bindtap="backupNow">手动备份</view>
  </view>

  <view wx:if="{{showRestore}}" class="sheet-mask">
    <view class="sheet-card">
      <text class="sheet-title">{{restoring ? '正在恢复数据' : '确认恢复数据'}}</text>
      <text class="sheet-desc">{{restoring ? '请勿关闭小程序，系统正在恢复最近一次备份。' : '恢复会覆盖当前工厂数据，请确认已经备份当前版本。'}}</text>
      <view wx:if="{{restoring}}" class="restore-bar"><view class="restore-fill"></view></view>
      <view wx:else class="sheet-actions">
        <view class="sheet-action outline" bindtap="closeRestore">取消</view>
        <view class="sheet-action primary" bindtap="confirmRestore">确认恢复</view>
      </view>
    </view>
  </view>
</view>
