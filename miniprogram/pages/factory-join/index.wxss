@import "../../styles/replica.wxss";

.join-page {
  min-height: 100vh;
  background: #FFFFFF;
}

.join-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 26rpx;
  padding: 76rpx 24rpx calc(72rpx + constant(safe-area-inset-bottom));
  padding: 76rpx 24rpx calc(72rpx + env(safe-area-inset-bottom));
}

.invite-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  background: #E8F0FE;
}

.invite-icon image {
  width: 44rpx;
  height: 44rpx;
}

.invite-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
}

.factory-info-card {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 28rpx;
  border-radius: 21rpx;
  background: #F3F4F6;
}

.factory-row,
.avatar-row,
.invite-meta {
  display: flex;
  align-items: center;
}

.factory-row {
  gap: 18rpx;
}

.factory-avatar {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 32rpx;
  background: #1A56DB;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
}

.factory-copy {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.factory-name {
  color: #111827;
  font-size: 27rpx;
  font-weight: 700;
}

.factory-address,
.staff-count,
.join-hint {
  color: #6B7280;
  font-size: 22rpx;
}

.invite-input {
  height: 84rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #FFFFFF;
  color: #111827;
  font-size: 26rpx;
  font-weight: 600;
}

.invite-placeholder {
  color: #9CA3AF;
  font-weight: 400;
}

.avatar-row {
  height: 40rpx;
}

.small-avatar {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: -8rpx;
  border: 2rpx solid #F3F4F6;
  border-radius: 20rpx;
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 700;
}

.small-avatar:first-child {
  margin-left: 0;
}

.avatar-0 {
  background: #F59E0B;
}

.avatar-1 {
  background: #10B981;
}

.avatar-2 {
  background: #3B82F6;
}

.avatar-3 {
  background: #EC4899;
}

.avatar-4 {
  background: #8B5CF6;
}

.invite-meta {
  gap: 10rpx;
  color: #111827;
  font-size: 22rpx;
}

.role-tag {
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  background: #DBEAFE;
  color: #1A56DB;
  font-size: 18rpx;
  font-weight: 600;
}

.join-button {
  width: 260rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #1A56DB;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}
