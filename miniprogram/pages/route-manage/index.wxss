@import "../../styles/replica.wxss";

.route-page {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: calc(72rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(72rpx + env(safe-area-inset-bottom));
}

.search-bar {
  height: 76rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 28rpx;
}

.mini-add {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 58rpx;
  border-radius: 12rpx;
  background: #1A56DB;
}

.mini-add image {
  width: 32rpx;
  height: 32rpx;
}

.search-box {
  flex: 1;
  height: 58rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  color: #9CA3AF;
  font-size: 23rpx;
}

.search-box image {
  width: 26rpx;
  height: 26rpx;
}

.count-text {
  display: block;
  padding: 10rpx 28rpx 16rpx;
  color: #6B7280;
  font-size: 22rpx;
}

.route-row {
  height: 124rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
  padding: 0 28rpx;
}

.route-top,
.route-title,
.route-actions {
  display: flex;
  align-items: center;
}

.route-top {
  justify-content: space-between;
  gap: 18rpx;
}

.route-title {
  gap: 10rpx;
}

.route-title text:first-child {
  color: #111827;
  font-size: 25rpx;
  font-weight: 700;
}

.route-title text:last-child {
  color: #1A56DB;
  font-size: 21rpx;
  font-weight: 700;
}

.route-actions {
  gap: 18rpx;
}

.route-actions image {
  width: 28rpx;
  height: 28rpx;
}

.route-steps {
  color: #6B7280;
  font-size: 22rpx;
}

.divider {
  height: 1px;
  margin-left: 28rpx;
  background: #F3F4F6;
}

.empty-route {
  margin: 64rpx 28rpx 0;
  min-height: 240rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 18rpx;
  background: #F9FAFB;
  color: #9CA3AF;
  text-align: center;
}

.empty-route text:first-child {
  color: #374151;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-route text:last-child {
  max-width: 520rpx;
  font-size: 23rpx;
  line-height: 34rpx;
}
