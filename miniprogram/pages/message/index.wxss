.message-page {
  min-height: 100vh;
  background: #F3F4F6;
}

.message-content {
  display: flex;
  flex-direction: column;
  gap: 21rpx;
  padding: 28rpx 28rpx calc(220rpx + constant(safe-area-inset-bottom));
  padding: 28rpx 28rpx calc(220rpx + env(safe-area-inset-bottom));
}

.read-all {
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 7rpx;
  color: #9CA3AF;
  font-size: 21rpx;
  line-height: 30rpx;
}

.read-icon {
  width: 23rpx;
  height: 23rpx;
}

.message-card {
  min-height: 169rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: 21rpx;
  background: #FFFFFF;
}

.message-icon-box {
  width: 84rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 84rpx;
  border-radius: 24rpx;
}

.message-icon-blue {
  background: rgba(26, 86, 219, 0.10);
}

.message-icon-amber {
  background: rgba(245, 158, 11, 0.10);
}

.message-icon-gray {
  background: rgba(107, 114, 128, 0.10);
}

.message-icon {
  width: 45rpx;
  height: 45rpx;
}

.message-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
}

.message-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 38rpx;
}

.message-preview {
  color: #6B7280;
  font-size: 23rpx;
  line-height: 33rpx;
}

.message-right {
  display: flex;
  align-items: center;
  flex: 0 0 auto;
  gap: 10rpx;
}

.unread-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #EF4444;
}

.message-arrow {
  width: 28rpx;
  height: 28rpx;
}
