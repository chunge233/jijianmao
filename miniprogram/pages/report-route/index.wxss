@import "../../styles/replica.wxss";

.route-page {
  min-height: 100vh;
  background: #F3F4F6;
}

.route-content {
  display: flex;
  flex-direction: column;
  gap: 17rpx;
  padding: 14rpx 14rpx calc(170rpx + constant(safe-area-inset-bottom));
  padding: 14rpx 14rpx calc(170rpx + env(safe-area-inset-bottom));
}

.mode-card,
.route-card,
.form-card {
  border-radius: 14rpx;
  background: #FFFFFF;
}

.mode-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 17rpx;
}

.mode-row {
  display: flex;
  align-items: center;
  gap: 42rpx;
}

.mode-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #6B7280;
  font-size: 23rpx;
}

.mode-item.is-active {
  color: #111827;
  font-weight: 600;
}

.mode-icon {
  width: 28rpx;
  height: 28rpx;
}

.select-trigger {
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  border-radius: 10rpx;
  background: #F3F4F6;
  color: #9CA3AF;
  font-size: 22rpx;
}

.trigger-icon,
.fold-icon {
  width: 26rpx;
  height: 26rpx;
}

.route-card {
  padding: 18rpx 20rpx;
}

.route-title-row,
.route-title-left,
.route-total,
.photo-title,
.submit-button,
.submit-action {
  display: flex;
  align-items: center;
}

.route-title-row,
.route-total,
.submit-button {
  justify-content: space-between;
}

.route-title-left {
  gap: 8rpx;
  color: #111827;
  font-size: 24rpx;
  font-weight: 700;
}

.route-mark {
  width: 5rpx;
  height: 24rpx;
  border-radius: 3rpx;
  background: #1A56DB;
}

.route-grid {
  display: grid;
  grid-template-columns: minmax(96rpx, 1fr) 100rpx 154rpx 112rpx;
  align-items: center;
  column-gap: 8rpx;
}

.table-head {
  margin-top: 18rpx;
  color: #6B7280;
  font-size: 20rpx;
  font-weight: 500;
}

.center {
  text-align: center;
}

.right {
  text-align: right;
}

.route-row {
  min-height: 54rpx;
  color: #111827;
  font-size: 23rpx;
}

.name-cell {
  display: flex;
  align-items: center;
  gap: 7rpx;
  font-weight: 600;
}

.terminal-tag {
  border-radius: 6rpx;
  padding: 2rpx 8rpx;
  background: #FEF3C7;
  color: #D97706;
  font-size: 16rpx;
  font-weight: 600;
}

.price-cell {
  color: #6B7280;
}

.stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.stepper-btn {
  width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.stepper-btn.minus {
  background: #F3F4F6;
  color: #6B7280;
}

.stepper-btn.plus {
  background: #1A56DB;
  color: #FFFFFF;
}

.stepper-value {
  width: 42rpx;
  color: #111827;
  font-size: 23rpx;
  font-weight: 600;
  text-align: center;
}

.subtotal-cell {
  color: #111827;
  font-weight: 700;
  text-align: right;
}

.route-total {
  margin-top: 10rpx;
  padding-top: 14rpx;
  border-top: 1px solid #F3F4F6;
  color: #EF4444;
  font-size: 22rpx;
  font-weight: 700;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 20rpx;
}

.form-label {
  color: #6B7280;
  font-size: 23rpx;
  font-weight: 500;
}

.remark-box {
  height: 124rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  color: #9CA3AF;
  font-size: 22rpx;
}

.photo-title {
  gap: 8rpx;
}

.photo-hint {
  color: #9CA3AF;
  font-size: 20rpx;
}

.photo-uploader {
  width: 150rpx;
  height: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
  color: #9CA3AF;
  font-size: 18rpx;
}

.photo-plus {
  width: 42rpx;
  height: 42rpx;
}

.submit-safe {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  padding: 16rpx 14rpx calc(16rpx + constant(safe-area-inset-bottom));
  padding: 16rpx 14rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
}

.submit-button {
  height: 80rpx;
  padding: 0 28rpx;
  border-radius: 14rpx;
  background: #1A56DB;
  color: #FFFFFF;
}

.submit-amount {
  font-size: 31rpx;
  font-weight: 700;
}

.submit-action {
  gap: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.submit-icon {
  width: 28rpx;
  height: 28rpx;
}
