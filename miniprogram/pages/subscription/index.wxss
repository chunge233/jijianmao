page {
  background: #F3F4F6;
}

.subscription-page {
  min-height: 100vh;
  background: #F3F4F6;
}

.subscription-scroll {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 28rpx 28rpx calc(166rpx + constant(safe-area-inset-bottom));
  padding: 28rpx 28rpx calc(166rpx + env(safe-area-inset-bottom));
}

.current-card {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
  padding: 30rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #1A56DB 0%, #1E3A8A 100%);
  color: #FFFFFF;
}

.current-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.current-top > view {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.eyebrow,
.current-desc {
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  line-height: 32rpx;
}

.current-title {
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 50rpx;
}

.status-pill {
  flex: 0 0 auto;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 48rpx;
}

.usage-row {
  display: flex;
  gap: 14rpx;
}

.usage-row view {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.12);
}

.usage-row text:first-child {
  color: rgba(255, 255, 255, 0.68);
  font-size: 20rpx;
  line-height: 28rpx;
}

.usage-row text:last-child {
  color: #FFFFFF;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.cycle-card,
.section {
  border-radius: 20rpx;
  background: #FFFFFF;
}

.cycle-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 24rpx;
}

.cycle-card > text {
  color: #059669;
  font-size: 22rpx;
  font-weight: 700;
}

.cycle-segment {
  display: flex;
  padding: 6rpx;
  border-radius: 14rpx;
  background: #F3F4F6;
}

.cycle-segment view {
  min-width: 112rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  color: #6B7280;
  font-size: 23rpx;
  font-weight: 700;
}

.cycle-segment .is-active {
  background: #1A56DB;
  color: #FFFFFF;
}

.section {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 24rpx;
}

.section-title text {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.plan-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 22rpx;
  border: 2rpx solid #F3F4F6;
  border-radius: 18rpx;
  background: #F9FAFB;
}

.plan-card.is-selected {
  border-color: #1A56DB;
  background: #EFF6FF;
}

.plan-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.plan-head image {
  width: 32rpx;
  height: 32rpx;
  flex: 0 0 32rpx;
}

.plan-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.plan-name-row > text:first-child {
  color: #111827;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.plan-badge {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #D1FAE5;
  color: #059669;
  font-size: 19rpx;
  font-weight: 700;
}

.plan-desc {
  display: block;
  margin-top: 4rpx;
  color: #6B7280;
  font-size: 22rpx;
  line-height: 32rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price-row text:first-child {
  color: #1A56DB;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.price-row text:nth-child(2) {
  color: #6B7280;
  font-size: 22rpx;
}

.origin-price {
  color: #9CA3AF !important;
  font-size: 21rpx !important;
  text-decoration: line-through;
}

.feature-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.feature-row text {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: #FFFFFF;
  color: #374151;
  font-size: 20rpx;
  line-height: 28rpx;
}

.seat-row {
  display: flex;
  gap: 14rpx;
}

.seat-chip {
  flex: 1;
  min-height: 76rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  border: 2rpx solid #F3F4F6;
  border-radius: 14rpx;
  color: #6B7280;
}

.seat-chip.is-active {
  border-color: #1A56DB;
  background: #DBEAFE;
  color: #1A56DB;
  font-weight: 700;
}

.seat-chip text:first-child {
  font-size: 24rpx;
  line-height: 32rpx;
}

.seat-chip text:last-child {
  font-size: 19rpx;
  line-height: 26rpx;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 20rpx 28rpx calc(20rpx + constant(safe-area-inset-bottom));
  padding: 20rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
}

.pay-button {
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  border-radius: 18rpx;
  background: #1A56DB;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
}

.pay-button text:last-child {
  font-size: 34rpx;
}
