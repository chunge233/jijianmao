<nav-bar title="我的"></nav-bar>

<view class="profile-page">
  <view class="profile-content">
    <view class="profile-card" bindtap="openProfileEdit">
      <view class="avatar {{!isLoggedIn ? 'avatar-guest' : ''}}">
        <image wx:if="{{!isLoggedIn}}" class="default-avatar-icon" src="{{defaultAvatarIcon}}" mode="aspectFit"></image>
        <text wx:else>{{userInitial}}</text>
        <view wx:if="{{isLoggedIn}}" class="avatar-upload">
          <image class="avatar-camera" src="/assets/icons/camera-white.svg" mode="aspectFit"></image>
        </view>
      </view>
      <view class="profile-info">
        <view class="name-row">
          <text class="profile-name">{{userName}}</text>
          <view wx:if="{{isLoggedIn}}" class="role-badge">{{userRole}}</view>
        </view>
        <view class="phone-row">
          <image class="phone-icon" src="/assets/icons/phone-gray.svg" mode="aspectFit"></image>
          <text>{{userPhone}}</text>
        </view>
      </view>
      <image class="card-arrow" src="/assets/icons/caret-right-gray.svg" mode="aspectFit"></image>
    </view>

    <view class="factory-card" bindtap="openFactorySelect">
      <image class="factory-icon" src="/assets/icons/buildings-gray.svg" mode="aspectFit"></image>
      <view class="factory-info">
        <text class="factory-label">当前工厂</text>
        <text class="factory-name">{{factoryName}}</text>
      </view>
      <image class="small-arrow" src="/assets/icons/caret-right-gray.svg" mode="aspectFit"></image>
    </view>

    <view class="stats-card">
      <view class="stats-title-row">
        <view class="stats-title-left">
          <view class="section-title-bar"></view>
          <text>我的统计</text>
        </view>
        <view wx:if="{{isLoggedIn && hasFactory}}" class="more-link" catchtap="openMoreStats">
          <text>更多</text>
          <image class="more-icon" src="/assets/icons/caret-right-blue.svg" mode="aspectFit"></image>
        </view>
      </view>
      <view class="stats-row">
        <block wx:for="{{stats}}" wx:key="label">
          <view class="stat-item">
            <view class="stat-icon-box stat-icon-{{item.iconTone}}">
              <image class="stat-icon" src="{{item.icon}}" mode="aspectFit"></image>
            </view>
            <text class="stat-value">{{item.value}}</text>
            <text class="stat-label">{{item.label}}</text>
          </view>
        </block>
      </view>
    </view>

    <view class="menu-card">
      <block wx:for="{{menus}}" wx:key="label">
        <view class="menu-row" data-index="{{index}}" data-path="{{item.path}}" bindtap="openMenu">
          <image class="menu-icon" src="{{item.icon}}" mode="aspectFit"></image>
          <text class="menu-label">{{item.label}}</text>
          <image class="menu-arrow" src="/assets/icons/caret-right-gray.svg" mode="aspectFit"></image>
        </view>
        <view wx:if="{{index < menus.length - 1}}" class="menu-divider"></view>
      </block>
    </view>

    <view wx:if="{{isLoggedIn}}" class="logout-button" bindtap="logout">退出登录</view>
  </view>
</view>
