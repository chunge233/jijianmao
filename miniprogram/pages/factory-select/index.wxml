<nav-bar show-back="{{true}}" back-text="" back-icon="/assets/icons/caret-left-black.svg" back-color="#111827"></nav-bar>

<view class="factory-select-page">
  <view class="factory-select-content">
    <view class="hero-illustration">
      <image class="hero-image" src="/assets/illustrations/iconscout-teamwork-brainstorming.png" mode="aspectFit"></image>
    </view>
    <text class="title">欢迎使用计件猫</text>
    <text class="subtitle">创建工厂，开始管理计件工资</text>

    <view class="option-list">
      <view class="option-card join is-disabled">
        <view class="option-icon muted">
          <image src="/assets/icons/users-three-blue.svg" mode="aspectFit"></image>
        </view>
        <view class="option-copy">
          <text class="option-title">加入工厂</text>
          <text class="option-desc">通过转发邀请进入，提交后等待审核</text>
        </view>
      </view>

      <view class="option-card create" bindtap="goCreate">
        <view class="option-icon white">
          <image src="/assets/icons/plus-circle-white.svg" mode="aspectFit"></image>
        </view>
        <view class="option-copy">
          <text class="option-title">创建工厂</text>
          <text class="option-desc">创建全新的工厂并管理计件工资</text>
        </view>
        <image class="arrow" src="/assets/icons/caret-right-white.svg" mode="aspectFit"></image>
      </view>
    </view>

  </view>
</view>
