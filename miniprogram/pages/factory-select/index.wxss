@import "../../styles/replica.wxss";

.factory-select-page {
  min-height: calc(100vh - 176rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

.factory-select-content {
  width: 100%;
  min-height: 0;
  flex: 1;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 28rpx;
  padding: 0 24rpx calc(96rpx + constant(safe-area-inset-bottom));
  padding: 0 24rpx calc(96rpx + env(safe-area-inset-bottom));
}

.hero-illustration {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.hero-image {
  width: 500rpx;
  height: 300rpx;
}

.title {
  color: #111827;
  font-size: 41rpx;
  font-weight: 700;
  line-height: 54rpx;
}

.subtitle {
  color: #6B7280;
  font-size: 25rpx;
  line-height: 36rpx;
  text-align: center;
}

.option-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 22rpx;
}

.option-card {
  height: 144rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 0 28rpx;
  border-radius: 21rpx;
  box-sizing: border-box;
}

.option-card.create {
  background: #1A56DB;
  color: #FFFFFF;
}

.option-card.join {
  background: #EEF6FF;
  border: 2rpx dashed #93C5FD;
}

.option-card.is-disabled {
  color: #64748B;
}

.option-card.is-disabled .option-title {
  color: #334155;
}

.option-card.is-disabled .option-desc {
  color: #64748B;
}

.option-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 56rpx;
  border-radius: 28rpx;
}

.option-icon.muted {
  background: #DBEAFE;
}

.option-icon.white {
  background: rgba(255, 255, 255, 0.14);
}

.option-icon image {
  width: 34rpx;
  height: 34rpx;
}

.option-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.option-title {
  color: #111827;
  font-size: 27rpx;
  font-weight: 700;
}

.create .option-title {
  color: #FFFFFF;
}

.option-desc {
  color: #6B7280;
  font-size: 21rpx;
}

.create .option-desc {
  color: #DBEAFE;
}

.arrow {
  width: 28rpx;
  height: 28rpx;
}

.footer-hint {
  color: #6B7280;
  font-size: 22rpx;
}
