<nav-bar title="消息详情" show-back="{{true}}"></nav-bar>

<view class="message-detail-page">
  <view class="message-detail-content">
    <view class="message-head-card">
      <view class="category-row">
        <view class="category-icon-box">
          <image src="/assets/icons/file-text-blue.svg" mode="aspectFit"></image>
        </view>
        <text>{{category}}</text>
      </view>
      <text class="message-title">{{title}}</text>
      <view class="meta-row">
        <text>{{meta}}</text>
        <text>{{time}}</text>
      </view>
    </view>

    <view class="body-card">
      <block wx:for="{{paragraphs}}" wx:key="*this">
        <text class="paragraph">{{item}}</text>
      </block>
    </view>

    <view class="source-card">
      <text class="source-label">消息来源</text>
      <text class="source-name">{{meta}}</text>
      <text class="source-id">消息编号：{{sourceId}}</text>
    </view>
  </view>
</view>
