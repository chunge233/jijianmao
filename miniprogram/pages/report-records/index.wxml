<nav-bar title="报工记录" show-back="{{true}}"></nav-bar>

<view class="records-page">
  <view class="status-tabs">
    <block wx:for="{{tabs}}" wx:key="label">
      <view class="tab-item {{item.active ? 'is-active' : ''}}" data-label="{{item.label}}" bindtap="switchTab">
        <text>{{item.label}}</text>
        <text>{{item.count}}</text>
      </view>
    </block>
  </view>

  <view class="filter-row">
    <view class="month-filter">
      <text>2026年6月</text>
      <image src="/assets/icons/caret-down-gray.svg" mode="aspectFit"></image>
    </view>
    <view class="chip-row">
      <block wx:for="{{chips}}" wx:key="*this">
        <view class="chip {{item === activeType ? 'is-active' : ''}}" data-type="{{item}}" bindtap="switchType">{{item}}</view>
      </block>
    </view>
  </view>

  <view class="records-list">
    <block wx:for="{{records}}" wx:key="id">
      <view class="record-card" data-path="{{item.path}}" bindtap="openRecord">
        <view class="record-top">
          <view>
            <text class="record-title">{{item.title}}</text>
            <view class="record-meta-line">
              <text class="type-tag">{{item.type}}</text>
              <text>{{item.count}}</text>
              <text class="record-amount">{{item.amount}}</text>
            </view>
          </view>
          <text class="status-tag tag-{{item.tone}}">{{item.status}}</text>
        </view>
        <view class="record-body">
          <view class="record-photo">
            <image src="/assets/icons/image-square-gray.svg" mode="aspectFit"></image>
          </view>
          <view class="record-copy">
            <text wx:if="{{item.note}}" class="record-note">{{item.note}}</text>
            <view class="audit-row">
              <text>{{item.worker}}</text>
              <text>{{item.reviewer}}</text>
            </view>
          </view>
        </view>
        <text class="record-time">{{item.time}}</text>
      </view>
    </block>
    <view wx:if="{{records.length === 0}}" class="empty-state">暂无报工记录</view>
  </view>
</view>
