<nav-bar title="工资明细" show-back="{{true}}"></nav-bar>

<view class="breakdown-page">
  <view class="breakdown-content">
    <view class="month-row">
      <text>2026年6月</text>
      <text>合计 ¥2,580.00</text>
    </view>

    <block wx:for="{{sections}}" wx:key="name">
      <view class="section-card">
        <view class="section-head">
          <view class="section-name-row">
            <view class="dot" style="background: {{item.color}};"></view>
            <text>{{item.name}}</text>
          </view>
          <view class="section-total">
            <text>{{item.meta}}</text>
            <text>{{item.total}}</text>
          </view>
        </view>
        <view class="divider"></view>
        <view class="break-grid table-head">
          <text>报工单号</text>
          <text>类型</text>
          <text>数量</text>
          <text>单价</text>
          <text>金额</text>
        </view>
        <block wx:for="{{item.rows}}" wx:for-item="row" wx:key="no">
          <view class="break-grid data-row">
            <text class="order-no">{{row.no}}</text>
            <text class="type-badge">{{row.type}}</text>
            <text>{{row.count}}</text>
            <text>{{row.price}}</text>
            <text class="amount">{{row.amount}}</text>
          </view>
        </block>
      </view>
    </block>
  </view>
</view>
