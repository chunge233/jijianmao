@import "../../styles/replica.wxss";

.employee-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 16rpx 24rpx calc(84rpx + constant(safe-area-inset-bottom));
  padding: 16rpx 24rpx calc(84rpx + env(safe-area-inset-bottom));
  background: #F5F7FB;
}

.top-tabs {
  height: 76rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx;
  border: 1rpx solid #E5E7EB;
  border-radius: 16rpx;
  background: #EEF4FF;
}

.top-tab {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 12rpx;
  color: #64748B;
  font-size: 24rpx;
  line-height: 34rpx;
}

.top-tab.is-active {
  background: #FFFFFF;
  color: #1A56DB;
  font-weight: 700;
  box-shadow: 0 10rpx 26rpx rgba(37, 99, 235, 0.12);
}

.tab-count {
  min-width: 34rpx;
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(100, 116, 139, 0.12);
  font-size: 20rpx;
  line-height: 34rpx;
}

.top-tab.is-active .tab-count {
  background: #DBEAFE;
  color: #1A56DB;
}

.search-box {
  height: 72rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border: 1rpx solid #EDF1F7;
  border-radius: 16rpx;
  background: #FFFFFF;
  color: #9CA3AF;
  font-size: 24rpx;
  line-height: 34rpx;
}

.search-box image {
  width: 28rpx;
  height: 28rpx;
  flex: 0 0 28rpx;
}

.role-tabs {
  display: flex;
  gap: 12rpx;
  padding: 18rpx 0 6rpx;
}

.role-chip {
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #64748B;
  font-size: 22rpx;
  line-height: 32rpx;
}

.role-chip.is-active {
  background: #1A56DB;
  color: #FFFFFF;
  font-weight: 700;
}

.employee-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 12rpx;
}

.employee-card {
  min-height: 124rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 18rpx 22rpx 22rpx;
  border: 1rpx solid #EEF2F7;
  border-radius: 16rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.05);
}

.avatar {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 68rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
}

.employee-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.employee-title-row,
.employee-meta-row {
  min-width: 0;
  display: flex;
  align-items: center;
}

.employee-title-row {
  gap: 12rpx;
}

.employee-name {
  overflow: hidden;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 38rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.employee-role {
  flex: 0 0 auto;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #EEF4FF;
  color: #1A56DB;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 28rpx;
}

.employee-meta-row {
  gap: 8rpx;
  color: #64748B;
  font-size: 22rpx;
  line-height: 32rpx;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  flex: 0 0 10rpx;
  border-radius: 999rpx;
  background: #22C55E;
}

.employee-card.is-left .status-dot {
  background: #EF4444;
}

.status-text {
  flex: 0 0 auto;
  color: #16A34A;
  font-weight: 600;
}

.employee-card.is-left .status-text {
  color: #DC2626;
}

.phone {
  overflow: hidden;
  min-width: 0;
  color: #64748B;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  width: 24rpx;
  height: 24rpx;
  flex: 0 0 24rpx;
}

.empty-state {
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 56rpx 28rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  text-align: center;
}

.empty-icon {
  width: 72rpx;
  height: 72rpx;
  opacity: 0.8;
}

.empty-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.empty-desc {
  color: #64748B;
  font-size: 22rpx;
  line-height: 32rpx;
}
