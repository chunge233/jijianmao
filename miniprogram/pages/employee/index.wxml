<nav-bar title="员工管理" show-back="{{true}}" back-text="" back-icon="/assets/icons/caret-left-black.svg" back-color="#111827"></nav-bar>

<view class="employee-page">
  <view class="top-tabs">
    <block wx:for="{{topTabs}}" wx:key="status">
      <view class="top-tab {{item.active ? 'is-active' : ''}}" data-status="{{item.status}}" bindtap="switchStatus">
        <text class="tab-label">{{item.label}}</text>
        <text class="tab-count">{{item.count}}</text>
      </view>
    </block>
  </view>

  <view class="search-box">
    <image src="/assets/icons/magnifying-glass-gray.svg" mode="aspectFit"></image>
    <text>搜索员工姓名...</text>
  </view>

  <view class="role-tabs">
    <block wx:for="{{roles}}" wx:key="*this">
      <view class="role-chip {{item === activeRole ? 'is-active' : ''}}" data-role="{{item}}" bindtap="switchRole">{{item}}</view>
    </block>
  </view>

  <view class="employee-list">
    <block wx:for="{{employees}}" wx:key="id">
      <view class="employee-card {{item.tag === '离职' ? 'is-left' : ''}}" data-id="{{item.id}}" bindtap="openEmployeeDetail">
        <view class="avatar" style="background: {{item.color}};">{{item.initial}}</view>
        <view class="employee-main">
          <view class="employee-title-row">
            <text class="employee-name">{{item.name}}</text>
            <text class="employee-role">{{item.role}}</text>
          </view>
          <view class="employee-meta-row">
            <view class="status-dot"></view>
            <text class="status-text">{{item.tag}}</text>
            <text class="phone">{{item.phone}}</text>
          </view>
        </view>
        <image class="arrow" src="/assets/icons/caret-right-gray.svg" mode="aspectFit"></image>
      </view>
    </block>
    <view wx:if="{{employees.length === 0}}" class="empty-state">
      <image class="empty-icon" src="/assets/icons/users-three-blue.svg" mode="aspectFit"></image>
      <text class="empty-title">暂无员工</text>
      <text class="empty-desc">切换状态或角色后仍没有匹配员工。</text>
    </view>
  </view>
</view>
