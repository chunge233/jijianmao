@import "../../styles/replica.wxss";

.manage-page {
  min-height: 100vh;
  background: #F3F4F6;
}

.manage-content {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 32rpx 28rpx calc(188rpx + constant(safe-area-inset-bottom));
  padding: 32rpx 28rpx calc(188rpx + env(safe-area-inset-bottom));
}

.manage-section {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.section-bar {
  width: 6rpx;
  height: 31rpx;
  border-radius: 4rpx;
  background: #1A56DB;
}

.manage-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.manage-card {
  width: calc((100% - 54rpx) / 4);
  height: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  color: #111827;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 32rpx;
}

.icon-box {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-box image {
  width: 52rpx;
  height: 52rpx;
}
