page {
  background: #F5F7FB;
}

.detail-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 20rpx 24rpx calc(188rpx + constant(safe-area-inset-bottom));
  padding: 20rpx 24rpx calc(188rpx + env(safe-area-inset-bottom));
  background: #F5F7FB;
}

.profile-card {
  position: relative;
  min-height: 210rpx;
  overflow: hidden;
  padding: 28rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #1A56DB 0%, #2563EB 52%, #0F766E 100%);
  color: #FFFFFF;
  box-shadow: 0 18rpx 46rpx rgba(37, 99, 235, 0.22);
}

.profile-card.is-disabled {
  background: linear-gradient(135deg, #475569 0%, #334155 100%);
  box-shadow: 0 18rpx 46rpx rgba(51, 65, 85, 0.18);
}

.profile-card::after {
  position: absolute;
  right: -90rpx;
  bottom: -120rpx;
  width: 360rpx;
  height: 240rpx;
  border-radius: 180rpx 0 0 0;
  background: rgba(255, 255, 255, 0.12);
  content: "";
}

.profile-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 96rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.38);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #FFFFFF;
  font-size: 38rpx;
  font-weight: 700;
}

.profile-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.profile-kicker {
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  line-height: 32rpx;
}

.profile-name {
  overflow: hidden;
  color: #FFFFFF;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 52rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-desc {
  color: rgba(255, 255, 255, 0.86);
  font-size: 23rpx;
  line-height: 34rpx;
}

.profile-status {
  flex: 0 0 auto;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 32rpx;
}

.metric-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.metric-card {
  width: calc((100% - 16rpx) / 2);
  box-sizing: border-box;
  min-height: 132rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #EEF2F7;
  border-radius: 16rpx;
  background: #FFFFFF;
}

.metric-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
  border-radius: 999rpx;
}

.metric-icon image {
  width: 34rpx;
  height: 34rpx;
}

.metric-blue {
  background: #DBEAFE;
}

.metric-green {
  background: #D1FAE5;
}

.metric-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.metric-label {
  color: #64748B;
  font-size: 22rpx;
  line-height: 32rpx;
}

.metric-value {
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.section-block {
  margin-top: 24rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 38rpx;
  margin-bottom: 16rpx;
}

.section-title-bar {
  width: 5rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: #1A56DB;
}

.section-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.info-card {
  overflow: hidden;
  border: 1rpx solid #EEF2F7;
  border-radius: 16rpx;
  background: #FFFFFF;
}

.info-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.info-row.is-last {
  border-bottom: 0;
}

.row-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 56rpx;
  border-radius: 999rpx;
  background: #F1F5FF;
}

.row-icon image {
  width: 30rpx;
  height: 30rpx;
}

.row-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.row-label {
  color: #64748B;
  font-size: 22rpx;
  line-height: 32rpx;
}

.row-value {
  overflow: hidden;
  color: #111827;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 36rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-value.code {
  white-space: normal;
  word-break: break-all;
}

.row-tag {
  flex: 0 0 auto;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 30rpx;
}

.row-tag.is-active {
  background: #D1FAE5;
  color: #059669;
}

.row-tag.is-disabled {
  background: #F1F5F9;
  color: #64748B;
}

.detail-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  gap: 18rpx;
  padding: 18rpx 24rpx calc(28rpx + constant(safe-area-inset-bottom));
  padding: 18rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #EEF2F7;
  background: #FFFFFF;
}

.bottom-button {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #1A56DB;
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.bottom-button.is-secondary {
  background: #F1F5F9;
  color: #334155;
}

.bottom-button.is-secondary.is-disabled {
  color: #94A3B8;
}

.state-card {
  min-height: 520rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 56rpx 32rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  text-align: center;
}

.state-icon {
  width: 82rpx;
  height: 82rpx;
}

.state-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.state-desc {
  color: #64748B;
  font-size: 23rpx;
  line-height: 34rpx;
}

.state-action {
  min-width: 220rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 14rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  background: #1A56DB;
  color: #FFFFFF;
  font-size: 25rpx;
  font-weight: 700;
}
