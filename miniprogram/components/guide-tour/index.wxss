.guide-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 2000;
  background: rgba(17, 24, 39, 0.72);
}

.guide-spot {
  position: fixed;
  z-index: 2001;
  border: 4rpx solid #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 0 0 9999px rgba(17, 24, 39, 0.58), 0 0 28rpx rgba(255, 255, 255, 0.75);
  pointer-events: none;
  transform: translateY(48rpx);
}

.guide-panel {
  position: fixed;
  right: 28rpx;
  left: 28rpx;
  z-index: 2002;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.18);
}

.panel-bottom {
  bottom: calc(156rpx + constant(safe-area-inset-bottom));
  bottom: calc(156rpx + env(safe-area-inset-bottom));
}

.panel-top-pos {
  top: calc(168rpx + constant(safe-area-inset-top));
  top: calc(168rpx + env(safe-area-inset-top));
}

.panel-middle {
  top: 42%;
  transform: translateY(-50%);
}

.panel-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.step-count {
  color: #1A56DB;
  font-size: 22rpx;
  font-weight: 700;
}

.close-text {
  color: #6B7280;
  font-size: 23rpx;
}

.guide-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.guide-desc {
  color: #6B7280;
  font-size: 24rpx;
  line-height: 38rpx;
}

.guide-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 6rpx;
}

.never-button,
.next-button {
  flex: 1;
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.never-button {
  background: #F3F4F6;
  color: #6B7280;
}

.next-button {
  background: #1A56DB;
  color: #FFFFFF;
}
