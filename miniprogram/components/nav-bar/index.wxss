.nav-bar {
  position: relative;
  z-index: 20;
  width: 100%;
  background: #FFFFFF;
}

.nav-status {
  width: 100%;
}

.nav-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 0 16px;
}

.nav-back,
.nav-right,
.nav-spacer {
  position: absolute;
  top: 50%;
  width: 52px;
  height: 22px;
  transform: translateY(-50%);
}

.nav-back {
  left: 16px;
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 14px;
  line-height: 20px;
}

.nav-back.is-icon-only {
  left: 8px;
  width: 44px;
  height: 44px;
  justify-content: center;
}

.nav-spacer {
  right: 16px;
}

.nav-right {
  right: 8px;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 20px;
  height: 20px;
}

.nav-right-icon {
  width: 20px;
  height: 20px;
}

.nav-title {
  max-width: 220px;
  overflow: hidden;
  color: #000000;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 17px;
  font-weight: 600;
  line-height: 25px;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}
