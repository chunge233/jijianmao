<view class="pen-screen {{viewScreen.theme === 'white' ? 'is-white' : ''}} {{viewScreen.theme === 'dark' ? 'is-dark' : ''}}">
  <nav-bar
    title="{{viewScreen.title || ''}}"
    show-back="{{viewScreen.showBack !== false}}"
    back-text=""
    back-icon="/assets/icons/caret-left-black.svg"
    back-color="{{viewScreen.theme === 'dark' ? '#FFFFFF' : '#111827'}}"
    right-icon="{{viewScreen.rightIcon || ''}}"
  ></nav-bar>

  <view class="pen-body {{viewScreen.bottomActions ? 'has-bottom-actions' : ''}}">
    <view wx:if="{{viewScreen.hero}}" class="pen-hero pen-hero-{{viewScreen.hero.tone || 'blue'}}">
      <view class="pen-hero-copy">
        <text class="pen-hero-kicker">{{viewScreen.hero.kicker}}</text>
        <text class="pen-hero-title">{{viewScreen.hero.title}}</text>
        <text wx:if="{{viewScreen.hero.desc}}" class="pen-hero-desc">{{viewScreen.hero.desc}}</text>
      </view>
      <view wx:if="{{viewScreen.hero.badge}}" class="pen-hero-badge">{{viewScreen.hero.badge}}</view>
    </view>

    <block wx:for="{{viewScreen.sections}}" wx:key="id">
      <view class="pen-section pen-section-{{item.type}}">
        <view wx:if="{{item.title || item.more}}" class="pen-section-head">
          <view wx:if="{{item.title}}" class="pen-section-title">
            <view class="pen-title-bar"></view>
            <text class="pen-section-title-text">{{item.title}}</text>
          </view>
          <view wx:if="{{item.more}}" class="pen-link" data-path="{{item.morePath}}" data-title="{{item.more}}" bindtap="emitAction">
            <text>{{item.more}}</text>
            <image class="pen-link-arrow" src="/assets/icons/caret-right-blue.svg" mode="aspectFit"></image>
          </view>
        </view>

        <view wx:if="{{item.type == 'notice'}}" class="pen-notice pen-notice-{{item.tone || 'blue'}}">
          <image wx:if="{{item.icon}}" class="pen-notice-icon" src="{{item.icon}}" mode="aspectFit"></image>
          <view class="pen-notice-copy">
            <text class="pen-notice-title">{{item.heading}}</text>
            <text class="pen-notice-desc">{{item.desc}}</text>
          </view>
        </view>

        <view wx:if="{{item.type == 'metrics'}}" class="pen-metrics columns-{{item.columns || 2}}">
          <block wx:for="{{item.items}}" wx:for-item="metric" wx:key="label">
            <view class="pen-metric">
              <view class="pen-icon-circle tone-{{metric.tone || 'blue'}}">
                <image wx:if="{{metric.icon}}" class="pen-icon-image" src="{{metric.icon}}" mode="aspectFit"></image>
                <text wx:else class="pen-icon-short">{{metric.short}}</text>
              </view>
              <view class="pen-metric-copy">
                <text class="pen-metric-label">{{metric.label}}</text>
                <text class="pen-metric-value">{{metric.value}}</text>
              </view>
            </view>
          </block>
        </view>

        <view wx:if="{{item.type == 'menuGrid'}}" class="pen-grid columns-{{item.columns || 2}}">
          <block wx:for="{{item.items}}" wx:for-item="entry" wx:key="title">
            <view class="pen-grid-card" data-id="{{entry.id}}" data-path="{{entry.path}}" data-action="{{entry.action}}" data-title="{{entry.title}}" bindtap="emitAction">
              <view class="pen-icon-circle tone-{{entry.tone || 'blue'}}">
                <image wx:if="{{entry.icon}}" class="pen-icon-image" src="{{entry.icon}}" mode="aspectFit"></image>
                <text wx:else class="pen-icon-short">{{entry.short}}</text>
              </view>
              <text class="pen-grid-title">{{entry.title}}</text>
              <text wx:if="{{entry.desc}}" class="pen-grid-desc">{{entry.desc}}</text>
            </view>
          </block>
        </view>

        <view wx:if="{{item.type == 'list'}}" class="pen-list">
          <block wx:for="{{item.items}}" wx:for-item="row" wx:key="title">
            <view class="pen-list-row {{index == item.items.length - 1 ? 'is-last' : ''}}" data-id="{{row.id}}" data-path="{{row.path}}" data-action="{{row.action}}" data-title="{{row.title}}" bindtap="emitAction">
              <view wx:if="{{row.icon || row.short}}" class="pen-row-icon tone-{{row.tone || 'gray'}}">
                <image wx:if="{{row.icon}}" class="pen-row-icon-image" src="{{row.icon}}" mode="aspectFit"></image>
                <text wx:else class="pen-row-icon-short">{{row.short}}</text>
              </view>
              <view class="pen-row-copy">
                <view class="pen-row-main">
                  <text class="pen-row-title">{{row.title}}</text>
                  <view wx:if="{{row.tag}}" class="pen-tag tag-{{row.tagTone || 'gray'}}">{{row.tag}}</view>
                </view>
                <text wx:if="{{row.desc}}" class="pen-row-desc">{{row.desc}}</text>
              </view>
              <text wx:if="{{row.value}}" class="pen-row-value">{{row.value}}</text>
              <image wx:if="{{row.path || row.action}}" class="pen-row-arrow" src="/assets/icons/caret-right-gray.svg" mode="aspectFit"></image>
            </view>
          </block>
        </view>

        <view wx:if="{{item.type == 'cards'}}" class="pen-cards">
          <block wx:for="{{item.items}}" wx:for-item="card" wx:key="title">
            <view class="pen-card" data-id="{{card.id}}" data-path="{{card.path}}" data-action="{{card.action}}" data-title="{{card.title}}" bindtap="emitAction">
              <view class="pen-card-top">
                <view class="pen-card-copy">
                  <text class="pen-card-title">{{card.title}}</text>
                  <text wx:if="{{card.desc}}" class="pen-card-desc">{{card.desc}}</text>
                </view>
                <view wx:if="{{card.tag}}" class="pen-tag tag-{{card.tagTone || 'gray'}}">{{card.tag}}</view>
              </view>
              <view wx:if="{{card.meta}}" class="pen-card-meta">
                <block wx:for="{{card.meta}}" wx:for-item="meta" wx:key="label">
                  <view class="pen-card-meta-item">
                    <text class="pen-card-meta-label">{{meta.label}}</text>
                    <text class="pen-card-meta-value">{{meta.value}}</text>
                  </view>
                </block>
              </view>
            </view>
          </block>
        </view>

        <view wx:if="{{item.type == 'form'}}" class="pen-form">
          <block wx:for="{{item.fields}}" wx:for-item="field" wx:key="label">
            <view class="pen-field {{field.multiline ? 'is-multiline' : ''}}">
              <text class="pen-field-label">{{field.label}}</text>
              <view class="pen-input {{field.placeholder ? 'is-placeholder' : ''}}">
                <text>{{field.value || field.placeholder}}</text>
              </view>
            </view>
          </block>
        </view>

        <view wx:if="{{item.type == 'summary'}}" class="pen-summary">
          <block wx:for="{{item.items}}" wx:for-item="summary" wx:key="label">
            <view class="pen-summary-item">
              <text class="pen-summary-label">{{summary.label}}</text>
              <text class="pen-summary-value">{{summary.value}}</text>
            </view>
          </block>
        </view>

        <view wx:if="{{item.type == 'steps'}}" class="pen-steps">
          <block wx:for="{{item.items}}" wx:for-item="step" wx:key="title">
            <view class="pen-step">
              <view class="pen-step-dot {{index == item.items.length - 1 ? 'is-last' : ''}}">{{index + 1}}</view>
              <view class="pen-step-copy">
                <text class="pen-step-title">{{step.title}}</text>
                <text class="pen-step-desc">{{step.desc}}</text>
              </view>
            </view>
          </block>
        </view>

        <view wx:if="{{item.type == 'timeline'}}" class="pen-timeline">
          <block wx:for="{{item.items}}" wx:for-item="event" wx:key="title">
            <view class="pen-time-row">
              <view class="pen-time-dot tone-{{event.tone || 'blue'}}"></view>
              <view class="pen-time-content">
                <view class="pen-time-head">
                  <text class="pen-time-title">{{event.title}}</text>
                  <text class="pen-time-value">{{event.time}}</text>
                </view>
                <text class="pen-time-desc">{{event.desc}}</text>
              </view>
            </view>
          </block>
        </view>

        <view wx:if="{{item.type == 'progress'}}" class="pen-progress-list">
          <block wx:for="{{item.items}}" wx:for-item="bar" wx:key="label">
            <view class="pen-progress-item">
              <view class="pen-progress-head">
                <text class="pen-progress-label">{{bar.label}}</text>
                <text class="pen-progress-value">{{bar.value}}</text>
              </view>
              <view class="pen-progress-track">
                <view class="pen-progress-fill" style="width: {{bar.width}}; background: {{bar.color}};"></view>
              </view>
            </view>
          </block>
        </view>

        <view wx:if="{{item.type == 'ranking'}}" class="pen-ranking">
          <block wx:for="{{item.items}}" wx:for-item="rank" wx:key="name">
            <view class="pen-rank-row">
              <view class="pen-rank-no {{index < 3 ? 'is-top' : ''}}">{{rank.rank}}</view>
              <view class="pen-avatar" style="background: {{rank.color}};">{{rank.short}}</view>
              <text class="pen-rank-name">{{rank.name}}</text>
              <text class="pen-rank-value">{{rank.value}}</text>
            </view>
          </block>
        </view>

        <view wx:if="{{item.type == 'empty'}}" class="pen-empty">
          <image wx:if="{{item.icon}}" class="pen-empty-icon" src="{{item.icon}}" mode="aspectFit"></image>
          <text class="pen-empty-title">{{item.title}}</text>
          <text class="pen-empty-desc">{{item.desc}}</text>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{viewScreen.bottomActions}}" class="pen-bottom">
    <text wx:if="{{viewScreen.bottomHint}}" class="pen-bottom-hint">{{viewScreen.bottomHint}}</text>
    <view class="pen-bottom-actions">
      <block wx:for="{{viewScreen.bottomActions}}" wx:key="title">
        <button
          wx:if="{{item.openType}}"
          class="pen-button {{item.type == 'secondary' ? 'is-secondary' : ''}} {{item.type == 'danger' ? 'is-danger' : ''}}"
          open-type="{{item.openType}}"
          data-path="{{item.path}}"
          data-action="{{item.action}}"
          data-title="{{item.title}}"
          bindtap="emitAction"
        >{{item.title}}</button>
        <view
          wx:else
          class="pen-button {{item.type == 'secondary' ? 'is-secondary' : ''}} {{item.type == 'danger' ? 'is-danger' : ''}}"
          data-path="{{item.path}}"
          data-action="{{item.action}}"
          data-title="{{item.title}}"
          bindtap="emitAction"
        >{{item.title}}</view>
      </block>
    </view>
  </view>

  <view wx:if="{{viewScreen.modal}}" class="pen-mask">
    <view class="pen-dialog">
      <view class="pen-dialog-icon tone-{{viewScreen.modal.tone || 'blue'}}">
        <image wx:if="{{viewScreen.modal.icon}}" class="pen-dialog-icon-img" src="{{viewScreen.modal.icon}}" mode="aspectFit"></image>
        <text wx:else>{{viewScreen.modal.short}}</text>
      </view>
      <text class="pen-dialog-title">{{viewScreen.modal.title}}</text>
      <text class="pen-dialog-desc">{{viewScreen.modal.desc}}</text>
      <view class="pen-dialog-actions">
        <block wx:for="{{viewScreen.modal.actions}}" wx:key="title">
          <view
            class="pen-dialog-button {{item.type == 'primary' ? 'is-primary' : ''}} {{item.type == 'danger' ? 'is-danger' : ''}}"
            data-path="{{item.path}}"
            data-action="{{item.action}}"
            data-title="{{item.title}}"
            bindtap="emitAction"
          >{{item.title}}</view>
        </block>
      </view>
    </view>
  </view>
</view>
