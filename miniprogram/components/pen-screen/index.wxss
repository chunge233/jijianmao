.pen-screen {
  position: relative;
  min-height: 100vh;
  background: #F3F4F6;
  color: #111827;
}

.pen-screen.is-white {
  background: #FFFFFF;
}

.pen-screen.is-dark {
  background: #000000;
  color: #FFFFFF;
}

.pen-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx 24rpx calc(72rpx + constant(safe-area-inset-bottom));
  padding: 24rpx 24rpx calc(72rpx + env(safe-area-inset-bottom));
}

.pen-body.has-bottom-actions {
  padding-bottom: calc(176rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(176rpx + env(safe-area-inset-bottom));
}

.pen-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 188rpx;
  padding: 28rpx 32rpx;
  overflow: hidden;
  border-radius: 22rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #1A56DB 0%, #1E3A8A 100%);
}

.pen-hero-green {
  background: linear-gradient(135deg, #059669 0%, #047857 100%);
}

.pen-hero-amber {
  background: linear-gradient(135deg, #D97706 0%, #B45309 100%);
}

.pen-hero-red {
  background: linear-gradient(135deg, #DC2626 0%, #991B1B 100%);
}

.pen-hero-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.pen-hero-kicker {
  color: #DBEAFE;
  font-size: 23rpx;
  line-height: 32rpx;
}

.pen-hero-title {
  color: #FFFFFF;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 54rpx;
}

.pen-hero-desc {
  color: rgba(255, 255, 255, 0.86);
  font-size: 23rpx;
  line-height: 34rpx;
}

.pen-hero-badge {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #FFFFFF;
  font-size: 23rpx;
  font-weight: 600;
}

.pen-section {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.pen-section-head {
  min-height: 38rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.pen-section-title {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.pen-section-title text {
  overflow: hidden;
  color: #111827;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 38rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pen-title-bar {
  width: 5rpx;
  height: 28rpx;
  border-radius: 4rpx;
  background: #1A56DB;
}

.pen-link {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: #1A56DB;
  font-size: 22rpx;
  line-height: 30rpx;
}

.pen-link image {
  width: 22rpx;
  height: 22rpx;
}

.pen-notice,
.pen-card,
.pen-list,
.pen-summary,
.pen-steps,
.pen-timeline,
.pen-empty {
  border-radius: 18rpx;
  background: #FFFFFF;
}

.pen-notice {
  display: flex;
  gap: 18rpx;
  padding: 20rpx 22rpx;
}

.pen-notice image {
  width: 34rpx;
  height: 34rpx;
  flex: 0 0 34rpx;
}

.pen-notice view {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.pen-notice text:first-child {
  color: #111827;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.pen-notice text:last-child {
  color: #6B7280;
  font-size: 22rpx;
  line-height: 32rpx;
}

.pen-notice-blue {
  background: #E8F0FE;
}

.pen-notice-green {
  background: #D1FAE5;
}

.pen-notice-amber {
  background: #FEF3C7;
}

.pen-notice-red {
  background: #FEE2E2;
}

.pen-metrics,
.pen-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.columns-2 .pen-metric,
.columns-2 .pen-grid-card {
  width: calc((100% - 18rpx) / 2);
}

.columns-3 .pen-metric,
.columns-3 .pen-grid-card {
  width: calc((100% - 36rpx) / 3);
}

.pen-metric,
.pen-grid-card {
  min-width: 0;
  min-height: 148rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
}

.pen-grid-card {
  flex-direction: column;
  align-items: flex-start;
  min-height: 170rpx;
}

.pen-grid-card > text:nth-child(2) {
  color: #111827;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.pen-grid-card > text:nth-child(3) {
  color: #6B7280;
  font-size: 21rpx;
  line-height: 30rpx;
}

.pen-icon-circle,
.pen-row-icon,
.pen-dialog-icon {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
}

.pen-icon-circle {
  width: 72rpx;
  height: 72rpx;
}

.pen-icon-circle image {
  width: 38rpx;
  height: 38rpx;
}

.pen-icon-circle text,
.pen-row-icon text {
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 700;
}

.tone-blue {
  background: #DBEAFE;
  color: #1A56DB;
}

.tone-green {
  background: #D1FAE5;
  color: #059669;
}

.tone-amber {
  background: #FEF3C7;
  color: #D97706;
}

.tone-red {
  background: #FEE2E2;
  color: #DC2626;
}

.tone-purple {
  background: #EDE9FE;
  color: #7C3AED;
}

.tone-gray {
  background: #F3F4F6;
  color: #6B7280;
}

.pen-metric-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.pen-metric-copy text:first-child {
  color: #6B7280;
  font-size: 23rpx;
  line-height: 32rpx;
}

.pen-metric-copy text:last-child {
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.pen-list {
  overflow: hidden;
}

.pen-list-row {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F3F4F6;
  background: #FFFFFF;
}

.pen-list-row:last-child {
  border-bottom: 0;
}

.pen-row-icon {
  width: 56rpx;
  height: 56rpx;
}

.pen-row-icon image {
  width: 32rpx;
  height: 32rpx;
}

.pen-row-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.pen-row-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.pen-row-main > text {
  overflow: hidden;
  color: #111827;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 36rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pen-row-copy > text {
  overflow: hidden;
  color: #6B7280;
  font-size: 21rpx;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pen-row-value {
  color: #6B7280;
  font-size: 23rpx;
  line-height: 32rpx;
}

.pen-row-arrow {
  width: 24rpx;
  height: 24rpx;
  flex: 0 0 24rpx;
}

.pen-tag {
  flex: 0 0 auto;
  padding: 5rpx 12rpx;
  border-radius: 8rpx;
  font-size: 19rpx;
  font-weight: 600;
  line-height: 28rpx;
}

.tag-blue {
  color: #1A56DB;
  background: #DBEAFE;
}

.tag-green {
  color: #059669;
  background: #D1FAE5;
}

.tag-amber {
  color: #D97706;
  background: #FEF3C7;
}

.tag-red {
  color: #DC2626;
  background: #FEE2E2;
}

.tag-gray {
  color: #6B7280;
  background: #F3F4F6;
}

.pen-cards {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.pen-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 24rpx;
}

.pen-card-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.pen-card-top > view:first-child {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.pen-card-top text:first-child {
  color: #111827;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.pen-card-top text:last-child {
  color: #6B7280;
  font-size: 22rpx;
  line-height: 32rpx;
}

.pen-card-meta,
.pen-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pen-card-meta view,
.pen-summary view {
  width: calc((100% - 16rpx) / 2);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.pen-card-meta text:first-child,
.pen-summary text:first-child {
  color: #6B7280;
  font-size: 21rpx;
  line-height: 30rpx;
}

.pen-card-meta text:last-child,
.pen-summary text:last-child {
  color: #111827;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.pen-summary {
  padding: 24rpx;
}

.pen-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.pen-field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.pen-field > text {
  color: #111827;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 34rpx;
}

.pen-input {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  color: #111827;
  font-size: 24rpx;
  line-height: 34rpx;
}

.pen-field.is-multiline .pen-input {
  min-height: 190rpx;
  align-items: flex-start;
  padding-top: 22rpx;
}

.pen-input.is-placeholder {
  color: #9CA3AF;
}

.pen-steps,
.pen-timeline {
  padding: 24rpx;
}

.pen-step,
.pen-time-row {
  display: flex;
  gap: 18rpx;
}

.pen-step + .pen-step,
.pen-time-row + .pen-time-row {
  margin-top: 24rpx;
}

.pen-step-dot {
  width: 44rpx;
  height: 44rpx;
  flex: 0 0 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #1A56DB;
  color: #FFFFFF;
  font-size: 23rpx;
  font-weight: 700;
}

.pen-step > view:last-child,
.pen-time-row > view:last-child {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.pen-step text:first-child,
.pen-time-row > view:last-child > view text:first-child {
  color: #111827;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.pen-step text:last-child,
.pen-time-row > view:last-child > text {
  color: #6B7280;
  font-size: 22rpx;
  line-height: 32rpx;
}

.pen-time-row > view:last-child > view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.pen-time-row > view:last-child > view text:last-child {
  flex: 0 0 auto;
  color: #9CA3AF;
  font-size: 20rpx;
}

.pen-time-dot {
  width: 18rpx;
  height: 18rpx;
  margin-top: 8rpx;
  border-radius: 999rpx;
}

.pen-progress-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
}

.pen-progress-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.pen-progress-item > view:first-child {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.pen-progress-item text:first-child {
  color: #111827;
  font-size: 25rpx;
  line-height: 34rpx;
}

.pen-progress-item text:last-child {
  color: #6B7280;
  font-size: 25rpx;
  font-weight: 700;
}

.pen-progress-track {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #F3F4F6;
}

.pen-progress-fill {
  height: 100%;
  border-radius: 999rpx;
}

.pen-ranking {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 10rpx 0;
}

.pen-rank-row {
  min-height: 74rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pen-rank-no,
.pen-avatar {
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
}

.pen-rank-no {
  background: #9CA3AF;
}

.pen-rank-no.is-top {
  background: #F59E0B;
}

.pen-rank-row > text:nth-last-child(2) {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 26rpx;
  line-height: 36rpx;
}

.pen-rank-row > text:last-child {
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
}

.pen-empty {
  min-height: 420rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 48rpx 32rpx;
}

.pen-empty image {
  width: 92rpx;
  height: 92rpx;
}

.pen-empty text:nth-child(2) {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.pen-empty text:nth-child(3) {
  color: #6B7280;
  font-size: 23rpx;
  line-height: 34rpx;
  text-align: center;
}

.pen-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 18rpx 24rpx calc(28rpx + constant(safe-area-inset-bottom));
  padding: 18rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
}

.pen-bottom-hint {
  color: #6B7280;
  font-size: 21rpx;
  line-height: 30rpx;
  text-align: center;
}

.pen-bottom-actions {
  display: flex;
  gap: 18rpx;
}

.pen-button,
.pen-dialog-button {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #1A56DB;
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 700;
}

.pen-button.is-secondary,
.pen-dialog-button {
  background: #F3F4F6;
  color: #111827;
}

.pen-button.is-danger,
.pen-dialog-button.is-danger {
  background: #DC2626;
  color: #FFFFFF;
}

.pen-dialog-button.is-primary {
  background: #1A56DB;
  color: #FFFFFF;
}

.pen-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 60;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.68);
}

.pen-dialog {
  width: 100%;
  max-width: 680rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  padding: 46rpx 34rpx 30rpx;
  border-radius: 28rpx;
  background: #FFFFFF;
}

.pen-dialog-icon {
  width: 96rpx;
  height: 96rpx;
}

.pen-dialog-icon image {
  width: 50rpx;
  height: 50rpx;
}

.pen-dialog > text:nth-child(2) {
  color: #111827;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-align: center;
}

.pen-dialog > text:nth-child(3) {
  color: #6B7280;
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: center;
}

.pen-dialog-actions {
  width: 100%;
  display: flex;
  gap: 18rpx;
  margin-top: 8rpx;
}
